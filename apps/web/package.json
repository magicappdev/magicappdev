{
  "name": "@magicappdev/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rimraf dist node_modules",
    "deploy": "npx wrangler deploy -c wrangler.toml",
    "dev": "vite -m dev",
    "format": "prettier --write .",
    "lint": "eslint . --ignore-pattern '*.d.ts'",
    "lint:fix": "eslint --fix .",
    "preview": "wrangler dev",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/kumo": "^1.15.0",
    "@cloudflare/vite-plugin": "^1.21.2",
    "@google/stitch-sdk": "^0.0.3",
    "@magicappdev/database": "workspace:*",
    "@magicappdev/shared": "workspace:*",
    "@marsidev/react-turnstile": "^1.1.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/themes": "^3.2.1",
    "agents": "^0.7.9",
    "ai": "^6.0.75",
    "hono": "^4.11.5",
    "lucide-react": "^0.562.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.1.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@hono/node-server": "^1.13.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.10",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  }
}
